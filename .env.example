# Copy this file to .env and replace every placeholder before deployment.
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local
PROJECT_NAME=NoteLLM
STACK_NAME=notellm
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# Generate unique values; never commit the resulting .env file.
SECRET_KEY=replace-with-a-random-secret
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-with-a-strong-password

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587
SENTRY_DSN=

# OpenAI-compatible provider configuration. Do not place these values in frontend variables.
LLM_BASE_URL=https://provider.example/v1
LLM_API_KEY=replace-with-provider-key
LLM_MODEL=replace-with-chat-model
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=replace-with-embedding-provider-key
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=1024

DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
